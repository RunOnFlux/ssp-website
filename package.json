{
  "name": "ssp-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS=\"--max-old-space-size=8192\" next dev",
    "prebuild": "tsx scripts/check-public-safe.ts && tsx scripts/check-agent-md-staleness.ts && tsx scripts/generate-chains-skill.ts",
    "build": "NODE_OPTIONS=\"--max-old-space-size=8192\" next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "check:public-safe": "tsx scripts/check-public-safe.ts",
    "check:agent-md-staleness": "tsx scripts/check-agent-md-staleness.ts",
    "agent-skills:generate": "tsx scripts/generate-chains-skill.ts",
    "pre-commit": "npm run lint:fix && npm run format",
    "check-all": "npm run type-check && npm run lint && npm run format:check && npm run test"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "~1.2.12",
    "@radix-ui/react-dialog": "~1.1.15",
    "@radix-ui/react-dropdown-menu": "~2.1.16",
    "@radix-ui/react-navigation-menu": "~1.2.14",
    "@radix-ui/react-slot": "~1.2.4",
    "@radix-ui/react-tabs": "~1.1.13",
    "@radix-ui/react-toast": "~1.2.15",
    "class-variance-authority": "~0.7.1",
    "clsx": "~2.1.1",
    "framer-motion": "~12.23.26",
    "gray-matter": "~4.0.3",
    "lru-cache": "~11.3.5",
    "lucide-react": "~0.560.0",
    "next": "~16.2.4",
    "next-intl": "~4.9.1",
    "next-themes": "~0.4.6",
    "react": "~19.2.3",
    "react-dom": "~19.2.3",
    "react-intersection-observer": "~10.0.0",
    "react-markdown": "~10.1.0",
    "rehype-pretty-code": "~0.14.3",
    "remark-gfm": "~4.0.1",
    "tailwind-merge": "~2.6.1",
    "tailwindcss-animate": "~1.0.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "~4.1.18",
    "@tailwindcss/typography": "~0.5.19",
    "@types/node": "~25.0.1",
    "@types/react": "~19.2.7",
    "@types/react-dom": "~19.2.3",
    "@typescript-eslint/eslint-plugin": "~8.49.0",
    "@typescript-eslint/parser": "~8.49.0",
    "@vitest/ui": "~4.1.5",
    "eslint": "~9.39.1",
    "eslint-config-next": "~16.2.4",
    "eslint-config-prettier": "~10.1.8",
    "eslint-plugin-import": "~2.32.0",
    "eslint-plugin-jsx-a11y": "~6.10.2",
    "eslint-plugin-prettier": "~5.5.4",
    "eslint-plugin-react": "~7.37.5",
    "eslint-plugin-react-hooks": "~7.0.1",
    "globals": "~16.5.0",
    "happy-dom": "~20.9.0",
    "postcss": "~8.5.6",
    "prettier": "~3.7.4",
    "prettier-plugin-tailwindcss": "~0.7.2",
    "tailwindcss": "~4.1.18",
    "tsx": "~4.21.0",
    "typescript": "~5.9.3",
    "vitest": "~4.1.5"
  },
  "keywords": [
    "crypto",
    "wallet",
    "blockchain",
    "bitcoin",
    "ethereum",
    "security"
  ],
  "author": "SSP Wallet",
  "license": "MIT",
  "description": "SSP Wallet - Secure, Simple, Powerful crypto wallet for multiple blockchains"
}
